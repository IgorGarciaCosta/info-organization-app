# Copy this file to ".env" for local development.
#
# EXPO_PUBLIC_API_URL is the base URL of the FastAPI backend that runs the
# Gemini summary. It is NOT a secret (it is a public URL), but it changes per
# environment. Anything prefixed with EXPO_PUBLIC_ is inlined into the app bundle
# by Expo at build time.
#
# - Development (USB + `adb reverse tcp:8000 tcp:8000`): http://localhost:8000
# - Production (installed APK): your hosted HTTPS backend, e.g.
#     https://your-backend.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:8000
