# Copy this file to ".env" (same folder) and paste your real Gemini API key.
# The ".env" file must NEVER be committed to git — it holds a secret.
#
# How to get the key:
#   1. Go to https://aistudio.google.com/apikey
#   2. Sign in with your Google account and click "Create API key".
#   3. Copy the generated key and paste it below (no quotes needed).
GEMINI_API_KEY=your_api_key_here
